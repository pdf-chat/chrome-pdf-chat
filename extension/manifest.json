{
  "manifest_version": 3,
  "name": "PDF Chat",
  "version": "1.0.0",
  "description": "Ask questions about any PDF open in your browser",
  "permissions": ["storage", "activeTab", "webRequest", "identity"],
  "oauth2": {
    "client_id": "51684954923-v4s0jo2j17bv895sgrbim178ddfatqjo.apps.googleusercontent.com",
    "scopes": ["openid", "email", "profile"]
  },
  "host_permissions": ["http://*/*", "https://*/*", "file:///*"],
  "background": {
    "service_worker": "service_worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/pdf.js", "content_script.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options/options.html",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none';"
  },
  "web_accessible_resources": [
    {
      "resources": ["lib/pdf.worker.js", "panel/panel.html", "panel/panel.css", "panel/panel.js"],
      "matches": ["http://*/*", "https://*/*", "file:///*"]
    }
  ]
}
